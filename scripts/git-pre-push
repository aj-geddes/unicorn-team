#!/usr/bin/env bash
set -e

# Pre-push hook - comprehensive quality gates before pushing to remote
# This hook runs more thorough checks than pre-commit

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Symbols for output
CHECKMARK="${GREEN}✓${NC}"
CROSSMARK="${RED}✗${NC}"
WARNING="${YELLOW}⚠${NC}"

# Function to print step header
print_step() {
    echo -e "\n${BLUE}▸${NC} $1"
}

# Function to print success
print_success() {
    echo -e "  ${CHECKMARK} $1"
}

# Function to print failure
print_failure() {
    echo -e "  ${CROSSMARK} $1"
}

# Function to print warning
print_warning() {
    echo -e "  ${WARNING} $1"
}

# Function to detect project type
detect_project_type() {
    local types=()

    if [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ]; then
        types+=("python")
    fi

    if [ -f "package.json" ]; then
        types+=("node")
    fi

    if [ -f "go.mod" ]; then
        types+=("go")
    fi

    if [ -f "Cargo.toml" ]; then
        types+=("rust")
    fi

    echo "${types[@]}"
}

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}    Pre-Push Quality Gates${NC}"
echo -e "${BLUE}========================================${NC}"

# Read from stdin the list of refs being pushed
while read local_ref local_sha remote_ref remote_sha; do
    # Check if we're pushing a branch (not deleting)
    if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
        # Extract branch name from ref
        BRANCH_NAME=$(echo "$local_ref" | sed 's/refs\/heads\///')

        # 1. Check if pushing to protected branch
        print_step "Checking branch protection"
        if [ "$BRANCH_NAME" = "main" ] || [ "$BRANCH_NAME" = "master" ]; then
            print_warning "Pushing to protected branch: $BRANCH_NAME"
            echo -e "  ${YELLOW}Are you sure you want to push directly to $BRANCH_NAME?${NC}"
            echo -e "  ${YELLOW}Consider using a feature branch and pull request.${NC}"
            read -p "  Continue? (y/N): " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                print_failure "Push aborted by user"
                exit 1
            fi
        else
            print_success "Branch is not protected: $BRANCH_NAME"
        fi

        # 2. Check for uncommitted changes
        print_step "Checking working tree"
        if ! git diff-index --quiet HEAD --; then
            print_failure "Uncommitted changes detected"
            echo -e "  ${RED}Cannot push with uncommitted changes${NC}"
            echo -e "  ${YELLOW}Commit or stash your changes first:${NC}"
            echo -e "    git add ."
            echo -e "    git commit -m 'your message'"
            exit 1
        fi
        if [ -n "$(git status --porcelain)" ]; then
            print_failure "Untracked or unstaged files detected"
            echo -e "  ${RED}Working tree is not clean${NC}"
            echo -e "  ${YELLOW}Commit all changes first:${NC}"
            echo -e "    git status"
            exit 1
        fi
        print_success "Working tree is clean"

        # 3. Check commit message format for commits being pushed
        print_step "Validating commit messages"
        if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
            # Get list of commits being pushed
            COMMITS=$(git rev-list "$remote_sha".."$local_sha")
        else
            # New branch, check all commits
            COMMITS=$(git rev-list "$local_sha")
        fi

        INVALID_COMMITS=0
        for commit in $COMMITS; do
            MSG=$(git log --format=%s -n 1 "$commit")
            # Check format: type(scope): description
            # Types: feat, fix, docs, skill, script, test, refactor, chore, style, perf
            if ! echo "$MSG" | grep -qE '^(feat|fix|docs|skill|script|test|refactor|chore|style|perf)\([a-z0-9-]+\): .+'; then
                print_failure "Invalid commit message format: $MSG"
                echo -e "  ${YELLOW}Expected format: type(scope): description${NC}"
                echo -e "  ${YELLOW}Types: feat, fix, docs, skill, script, test, refactor, chore, style, perf${NC}"
                echo -e "  ${YELLOW}Example: feat(orchestrator): add delegation matrix${NC}"
                INVALID_COMMITS=$((INVALID_COMMITS + 1))
            fi
        done

        if [ $INVALID_COMMITS -gt 0 ]; then
            print_failure "$INVALID_COMMITS commit(s) with invalid message format"
            echo -e "  ${YELLOW}Fix with: git rebase -i HEAD~N${NC}"
            exit 1
        fi
        print_success "All commit messages properly formatted"
    fi
done

# Detect project types
PROJECT_TYPES=($(detect_project_type))

if [ ${#PROJECT_TYPES[@]} -eq 0 ]; then
    print_warning "No project type detected (no pyproject.toml, package.json, go.mod, or Cargo.toml)"
    echo -e "  ${YELLOW}Skipping language-specific checks${NC}"
fi

# 4. Run full test suite
print_step "Running full test suite"
TESTS_PASSED=false

if [[ " ${PROJECT_TYPES[@]} " =~ " python " ]]; then
    if command_exists pytest; then
        echo -e "  ${BLUE}Running pytest...${NC}"
        if pytest -v --tb=short 2>&1 | tee /tmp/pytest_output.txt; then
            print_success "Python tests passed"
            TESTS_PASSED=true
        else
            print_failure "Python tests failed"
            echo -e "  ${YELLOW}Fix failing tests before pushing${NC}"
            exit 1
        fi
    else
        print_warning "pytest not found, skipping Python tests"
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " node " ]]; then
    if [ -f "package.json" ] && grep -q '"test"' package.json; then
        if command_exists npm; then
            echo -e "  ${BLUE}Running npm test...${NC}"
            if npm test; then
                print_success "Node tests passed"
                TESTS_PASSED=true
            else
                print_failure "Node tests failed"
                echo -e "  ${YELLOW}Fix failing tests before pushing${NC}"
                exit 1
            fi
        else
            print_warning "npm not found, skipping Node tests"
        fi
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " go " ]]; then
    if command_exists go; then
        echo -e "  ${BLUE}Running go test...${NC}"
        if go test ./...; then
            print_success "Go tests passed"
            TESTS_PASSED=true
        else
            print_failure "Go tests failed"
            echo -e "  ${YELLOW}Fix failing tests before pushing${NC}"
            exit 1
        fi
    else
        print_warning "go not found, skipping Go tests"
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " rust " ]]; then
    if command_exists cargo; then
        echo -e "  ${BLUE}Running cargo test...${NC}"
        if cargo test; then
            print_success "Rust tests passed"
            TESTS_PASSED=true
        else
            print_failure "Rust tests failed"
            echo -e "  ${YELLOW}Fix failing tests before pushing${NC}"
            exit 1
        fi
    else
        print_warning "cargo not found, skipping Rust tests"
    fi
fi

if [ "$TESTS_PASSED" = false ] && [ ${#PROJECT_TYPES[@]} -gt 0 ]; then
    print_warning "No tests were executed"
fi

# 5. Check test coverage
print_step "Checking test coverage"
COVERAGE_THRESHOLD=80

if [[ " ${PROJECT_TYPES[@]} " =~ " python " ]]; then
    if command_exists pytest; then
        echo -e "  ${BLUE}Checking Python coverage (threshold: ${COVERAGE_THRESHOLD}%)...${NC}"
        if pytest --cov=. --cov-report=term --cov-fail-under=$COVERAGE_THRESHOLD -q 2>&1 | tee /tmp/coverage_output.txt; then
            print_success "Coverage meets threshold (≥${COVERAGE_THRESHOLD}%)"
        else
            print_failure "Coverage below threshold (${COVERAGE_THRESHOLD}%)"
            echo -e "  ${YELLOW}Increase test coverage before pushing${NC}"
            echo -e "  ${YELLOW}Run: pytest --cov=. --cov-report=html${NC}"
            exit 1
        fi
    else
        print_warning "pytest-cov not installed, skipping coverage check"
        echo -e "  ${YELLOW}Install with: pip install pytest-cov${NC}"
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " node " ]]; then
    if [ -f "package.json" ] && grep -q '"test".*--coverage' package.json; then
        echo -e "  ${BLUE}Checking Node coverage...${NC}"
        if npm test -- --coverage --coverageThreshold='{"global":{"lines":'$COVERAGE_THRESHOLD'}}' 2>&1; then
            print_success "Coverage meets threshold"
        else
            print_warning "Coverage check unavailable or failed"
        fi
    fi
fi

# 6. Run security scans
print_step "Running security scans"

if [[ " ${PROJECT_TYPES[@]} " =~ " python " ]]; then
    if command_exists bandit; then
        echo -e "  ${BLUE}Running bandit security scan...${NC}"
        if bandit -r . -ll -q 2>&1 | tee /tmp/bandit_output.txt; then
            print_success "Python security scan passed"
        else
            print_failure "Security issues detected by bandit"
            echo -e "  ${YELLOW}Review and fix security issues before pushing${NC}"
            echo -e "  ${YELLOW}Run: bandit -r . -ll${NC}"
            exit 1
        fi
    else
        print_warning "bandit not found, skipping Python security scan"
        echo -e "  ${YELLOW}Install with: pip install bandit${NC}"
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " node " ]]; then
    if [ -f "package-lock.json" ] || [ -f "yarn.lock" ]; then
        if command_exists npm; then
            echo -e "  ${BLUE}Running npm audit...${NC}"
            # npm audit returns non-zero for vulnerabilities, but we'll be lenient
            if npm audit --audit-level=high 2>&1 | tee /tmp/npm_audit_output.txt; then
                print_success "No high-severity vulnerabilities found"
            else
                print_warning "Vulnerabilities detected in dependencies"
                echo -e "  ${YELLOW}Consider running: npm audit fix${NC}"
                # Don't fail, just warn for dependencies
            fi
        fi
    fi
fi

# 7. Check for quality markers (TODO, FIXME, HACK)
print_step "Checking for quality markers"
if git grep -n -E "TODO|FIXME|HACK|XXX" -- '*.py' '*.js' '*.ts' '*.go' '*.rs' 2>/dev/null | grep -v "pre-push" | grep -v "pre-commit"; then
    print_failure "Found TODO/FIXME/HACK markers in code"
    echo -e "  ${YELLOW}Remove or track these before pushing:${NC}"
    echo -e "  ${YELLOW}Either complete the work or create issues${NC}"
    exit 1
else
    print_success "No quality markers found"
fi

# 8. Build check (if applicable)
print_step "Checking build"

if [[ " ${PROJECT_TYPES[@]} " =~ " node " ]]; then
    if [ -f "package.json" ] && grep -q '"build"' package.json; then
        if command_exists npm; then
            echo -e "  ${BLUE}Running npm build...${NC}"
            if npm run build; then
                print_success "Build succeeded"
            else
                print_failure "Build failed"
                echo -e "  ${YELLOW}Fix build errors before pushing${NC}"
                exit 1
            fi
        fi
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " go " ]]; then
    if command_exists go; then
        echo -e "  ${BLUE}Running go build...${NC}"
        if go build ./...; then
            print_success "Go build succeeded"
        else
            print_failure "Go build failed"
            echo -e "  ${YELLOW}Fix build errors before pushing${NC}"
            exit 1
        fi
    fi
fi

if [[ " ${PROJECT_TYPES[@]} " =~ " rust " ]]; then
    if command_exists cargo; then
        echo -e "  ${BLUE}Running cargo build...${NC}"
        if cargo build; then
            print_success "Rust build succeeded"
        else
            print_failure "Rust build failed"
            echo -e "  ${YELLOW}Fix build errors before pushing${NC}"
            exit 1
        fi
    fi
fi

# Final success message
echo -e "\n${GREEN}========================================${NC}"
echo -e "${GREEN}    All Pre-Push Checks Passed!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}Ready to push to remote${NC}\n"

exit 0
